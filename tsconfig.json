{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["cypress", "node"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "sourceMap": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "cypress/**/*.ts",
    "cypress.config.ts"
  ]
}